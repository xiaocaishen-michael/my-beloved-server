# Copy to .env (or use direnv with .envrc) for local development.
# Real values must NEVER be committed — gitleaks pre-commit hook will block.

# Database
DATASOURCE_URL=jdbc:postgresql://localhost:5432/mbw
DATASOURCE_USERNAME=mbw
DATASOURCE_PASSWORD=

# Server
SERVER_PORT=8080

# Flyway schemas (comma-separated)
FLYWAY_SCHEMAS=shared

# JWT (M1.1+)
# JWT_PRIVATE_KEY_PATH=
# JWT_PUBLIC_KEY_PATH=

# Aliyun SMS (M1.1+)
# ALIYUN_SMS_ACCESS_KEY_ID=
# ALIYUN_SMS_ACCESS_KEY_SECRET=
# ALIYUN_SMS_SIGN_NAME=
# ALIYUN_SMS_TEMPLATE_CODE=

# Google OAuth id_token verification (M1.2+)
# GOOGLE_CLIENT_ID=

# WeChat Open Platform (M1.3+)
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=
