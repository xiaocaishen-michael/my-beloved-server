# Copy to .env (or use direnv with .envrc) for local development.
# Real values must NEVER be committed — gitleaks pre-commit hook will block.
#
# Spring Boot Relaxed Binding maps the env names below to the keys in
# application.yml (e.g. MBW_AUTH_JWT_SECRET → mbw.auth.jwt.secret).

# ---- Database ----
DATASOURCE_URL=jdbc:postgresql://localhost:5432/mbw
DATASOURCE_USERNAME=mbw
# Match POSTGRES_PASSWORD in docker-compose.dev.yml (default: mbw).
DATASOURCE_PASSWORD=

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- Server ----
SERVER_PORT=8080

# ---- Flyway (comma-separated, must include every active module schema) ----
FLYWAY_SCHEMAS=shared,account

# ---- JWT (required at startup; @NotBlank in JwtProperties) ----
# 32+ bytes of entropy. Tests use a fixed dev string; rotate per-env.
MBW_AUTH_JWT_SECRET=

# ---- SMS provider ----
# Pick exactly one: mock | aliyun | log (default = log via matchIfMissing).
#   mock   → MockSmsCodeSender → email via the EmailSender below (M1 default
#            recommended; see ADR-0013).
#   aliyun → AliyunSmsClient (production once 营业执照 + 签名 approved).
#   log    → LoggingSmsClient (logs intent only, never sends).
MBW_SMS_PROVIDER=

# ---- Email provider (required when MBW_SMS_PROVIDER=mock) ----
# Pick: resend | log (default = log via matchIfMissing).
#   resend → ResendEmailClient hits HTTPS api.resend.com.
#   log    → LoggingEmailSender (logs to/from/subject only, no body).
MBW_EMAIL_PROVIDER=

# ---- Resend (required when MBW_EMAIL_PROVIDER=resend) ----
RESEND_API_KEY=
# Override only if testing against a Resend mock; default points to prod.
# RESEND_BASE_URL=https://api.resend.com
# RESEND_CONNECT_TIMEOUT=5s
# RESEND_READ_TIMEOUT=10s

# ---- Mock SMS recipient (required when MBW_SMS_PROVIDER=mock) ----
# All "SMS" verification emails land here in dev/staging.
MOCK_SMS_RECIPIENT=
# Must be on a domain verified in your Resend account.
MOCK_SMS_FROM=

# ---- Aliyun SMS (required when MBW_SMS_PROVIDER=aliyun) ----
# ALIYUN_SMS_AK=
# ALIYUN_SMS_SK=
# ALIYUN_SMS_SIGN=
# mbw.sms.template.login-unregistered — set after Aliyun Template C is approved.
# MBW_SMS_TEMPLATE_LOGIN_UNREGISTERED=

# ---- Google OAuth id_token verification (M1.2+) ----
# GOOGLE_CLIENT_ID=

# ---- WeChat Open Platform (M1.3+) ----
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=
