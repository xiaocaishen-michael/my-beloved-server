# Copy to .env.app (on the App node) before running docker-compose.app.yml.
# Real values must NEVER be committed — gitleaks pre-commit hook will block.

# === Image version ===
# Set to a release tag (e.g. v0.1.5) to pin; default `latest` follows main.
MBW_VERSION=latest

# Override for local dry-run with a locally-built image:
#   docker build -t mbw-app:dev .
# MBW_APP_IMAGE=mbw-app:dev

# === Data node connectivity ===
# Intranet IP of the Data ECS (e.g. 172.16.0.5). Use host.docker.internal
# for local dry-run on macOS / Windows.
DATA_NODE_HOST=

# Must match .env.data on the Data node — DB / Redis won't accept connections
# with mismatched credentials.
DB_USERNAME=mbw
DB_PASSWORD=
REDIS_PASSWORD=

# Flyway schemas (comma-separated)
FLYWAY_SCHEMAS=shared,account

# === Auth ===
# Generate with: openssl rand -hex 32
JWT_SECRET=

# === SMS 通道（ADR-0013）===
# M1 阶段走邮件 mock（阿里云短信资质审核未通过期间过渡）。
# 选项：mock / aliyun / 空（→ LoggingSmsClient 兜底）
MBW_SMS_PROVIDER=mock

# Mock 通道：发件 / 收件邮箱（收件人写死给开发者，不暴露给最终用户）
# MockSmsCodeSender 走 EmailSender 抽象 → ResendEmailClient（详 Email 通道节）
MOCK_SMS_RECIPIENT=zhangleipd@aliyun.com
MOCK_SMS_FROM=noreply@mail.xiaocaishen.me

# Aliyun 真发短信（M1 不激活；营业执照 + 签名审核通过后切此 provider）
# MBW_SMS_PROVIDER=aliyun
# ALIYUN_SMS_AK=
# ALIYUN_SMS_SK=
# ALIYUN_SMS_SIGN=

# === Email 通道（ADR-0013 二次 amend, 2026-04-30）===
# 选项：resend / 空（→ LoggingEmailSender 仅 log 不发件，开发期兜底）
MBW_EMAIL_PROVIDER=resend

# Resend HTTPS API：API key 在 resend.com 控制台 "API Keys" 创建（仅 send 权限）；
# 发信域 mail.xiaocaishen.me 须在 Resend 控制台 "Domains" 加 + 阿里云 DNS 配齐
# SPF/DKIM/DMARC 三条 TXT records + verify 通过后才能发件成功。
RESEND_API_KEY=
# 默认走 Resend 美区主端点；如需改 region 端点（不常见）覆盖此变量
# RESEND_BASE_URL=https://api.resend.com
# 国内 ECS 出境到 Resend 偶有延迟，必要时调高（默认 5s/10s）
# RESEND_CONNECT_TIMEOUT=5s
# RESEND_READ_TIMEOUT=10s

# === Aliyun OSS (placeholder, M1.1 unused) ===
# Pre-wired endpoint; M1.1 register-by-phone has no S3 callsite. Filled in
# when an upload use case (avatars / note attachments) lands.
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_BUCKET=
# OSS_AK=
# OSS_SK=
