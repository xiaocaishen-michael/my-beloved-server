{
  "openapi" : "3.1.0",
  "info" : {
    "title" : "OpenAPI definition"
  },
  "paths" : {
    "/api/v1/sms-codes" : {
      "post" : {
        "tags" : [ "account-register-controller" ],
        "operationId" : "requestSmsCode",
        "requestBody" : {
          "content" : {
            "application/json" : {
              "schema" : {
                "$ref" : "#/components/schemas/RequestSmsCodeRequest"
              }
            }
          },
          "required" : true
        },
        "responses" : {
          "200" : {
            "description" : "OK"
          }
        }
      }
    },
    "/api/v1/auth/login-by-phone-sms" : {
      "post" : {
        "tags" : [ "auth-controller" ],
        "operationId" : "loginByPhoneSms",
        "requestBody" : {
          "content" : {
            "application/json" : {
              "schema" : {
                "$ref" : "#/components/schemas/LoginByPhoneSmsRequest"
              }
            }
          },
          "required" : true
        },
        "responses" : {
          "200" : {
            "description" : "OK",
            "content" : {
              "*/*" : {
                "schema" : {
                  "$ref" : "#/components/schemas/LoginResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/login-by-password" : {
      "post" : {
        "tags" : [ "auth-controller" ],
        "operationId" : "loginByPassword",
        "requestBody" : {
          "content" : {
            "application/json" : {
              "schema" : {
                "$ref" : "#/components/schemas/LoginByPasswordRequest"
              }
            }
          },
          "required" : true
        },
        "responses" : {
          "200" : {
            "description" : "OK",
            "content" : {
              "*/*" : {
                "schema" : {
                  "$ref" : "#/components/schemas/LoginResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/accounts/register-by-phone" : {
      "post" : {
        "tags" : [ "account-register-controller" ],
        "operationId" : "registerByPhone",
        "requestBody" : {
          "content" : {
            "application/json" : {
              "schema" : {
                "$ref" : "#/components/schemas/RegisterByPhoneRequest"
              }
            }
          },
          "required" : true
        },
        "responses" : {
          "200" : {
            "description" : "OK",
            "content" : {
              "*/*" : {
                "schema" : {
                  "$ref" : "#/components/schemas/RegisterByPhoneResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components" : {
    "schemas" : {
      "RequestSmsCodeRequest" : {
        "type" : "object",
        "properties" : {
          "phone" : {
            "type" : "string",
            "minLength" : 1
          },
          "purpose" : {
            "type" : "string",
            "enum" : [ "REGISTER", "LOGIN" ]
          }
        },
        "required" : [ "phone" ]
      },
      "LoginByPhoneSmsRequest" : {
        "type" : "object",
        "properties" : {
          "phone" : {
            "type" : "string",
            "minLength" : 1
          },
          "code" : {
            "type" : "string",
            "minLength" : 1,
            "pattern" : "^\\d{6}$"
          }
        },
        "required" : [ "code", "phone" ]
      },
      "LoginResponse" : {
        "type" : "object",
        "properties" : {
          "accountId" : {
            "type" : "integer",
            "format" : "int64"
          },
          "accessToken" : {
            "type" : "string"
          },
          "refreshToken" : {
            "type" : "string"
          }
        }
      },
      "LoginByPasswordRequest" : {
        "type" : "object",
        "properties" : {
          "phone" : {
            "type" : "string",
            "minLength" : 1
          },
          "password" : {
            "type" : "string",
            "minLength" : 1
          }
        },
        "required" : [ "password", "phone" ]
      },
      "RegisterByPhoneRequest" : {
        "type" : "object",
        "properties" : {
          "phone" : {
            "type" : "string",
            "minLength" : 1
          },
          "code" : {
            "type" : "string",
            "minLength" : 1
          },
          "password" : {
            "type" : "string"
          }
        },
        "required" : [ "code", "phone" ]
      },
      "RegisterByPhoneResponse" : {
        "type" : "object",
        "properties" : {
          "accountId" : {
            "type" : "integer",
            "format" : "int64"
          },
          "accessToken" : {
            "type" : "string"
          },
          "refreshToken" : {
            "type" : "string"
          }
        }
      }
    }
  }
}
