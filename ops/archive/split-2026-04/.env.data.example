# Copy to .env.data (on the Data node) before running docker-compose.data.yml.
# Real values must NEVER be committed — gitleaks pre-commit hook will block.

# === DB credentials ===
# Must match the values in the App node's .env.app.
# Generate password with: openssl rand -hex 32
DB_USERNAME=mbw
DB_PASSWORD=

# === Redis ===
# Generate password with: openssl rand -hex 32
REDIS_PASSWORD=

# === Backup target (Phase 3 cron) ===
# OSS bucket the daily pg_dump cron uploads to. Created in Aliyun OSS
# console; AccessKey is a sub-user with write-only permission to this
# bucket (least-privilege).
# OSS_BACKUP_BUCKET=
# OSS_BACKUP_AK=
# OSS_BACKUP_SK=
