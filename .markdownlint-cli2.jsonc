{
  // Doc-heavy repo. Keep relaxed but catch real issues.
  "config": {
    "default": true,
    "MD013": false,        // Line length — Chinese mixed text gets noisy
    "MD033": false,        // Inline HTML — used in README badges, ADR diagrams
    "MD041": false,        // First line H1 — frontmatter / templates start otherwise
    "MD024": { "siblings_only": true },  // Duplicate headers OK across sections
    "MD007": { "indent": 2 },
    "MD026": { "punctuation": ".,;:!" }, // Allow ? in headers (FAQ style)
    "MD040": true,         // Fenced code lang required
    "MD025": true,         // Single H1 per file
    "MD034": true,         // No bare URLs
    "MD060": false,        // Table pipe spacing — purely cosmetic, both styles valid
    "MD032": false         // Blanks-around-lists — markdownlint 自创防御规则(只为 kramdown 兼容);CommonMark/GFM/GitHub/VS Code/pandoc 都不需要;prettier preset 默认 disable;中文 SDD doc 主要磨损源
  },
  "ignores": [
    "**/target/**",
    "**/node_modules/**",
    "**/.git/**",
    ".specify/**",         // spec-kit autogenerated
    ".claude/skills/**",   // spec-kit skill files autogenerated
    "**/CHANGELOG.md"      // release-please autogenerated
  ]
}
