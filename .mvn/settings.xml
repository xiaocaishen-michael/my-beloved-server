<?xml version="1.0" encoding="UTF-8"?>
<!--
  Maven settings used by the Docker build (passed via `mvnw -s .mvn/settings.xml`).

  =====================================================================
  Loading rule (重要项目隐性约定，不要破坏)：
  =====================================================================
  This file is loaded ONLY when `-s .mvn/settings.xml` is explicitly
  passed to mvnw. Maven does NOT auto-discover `.mvn/settings.xml`
  (only `~/.m2/settings.xml` and `$M2_HOME/conf/settings.xml`).

  - Dockerfile RUN ./mvnw ... 显式带 `-s .mvn/settings.xml`  → 用本文件
  - .github/workflows/ci.yml 跑 `./mvnw verify`（无 -s）       → 不用本文件
  - 本地 ./mvnw ... 不带 -s                                    → 不用本文件
  - .mvn/maven.config 当前不存在；不要往里面写 `-s`，否则会让
    所有 mvnw 调用（含 PR CI / 本地 dev）被迫走本文件 → US runner
    上的 PR CI 会跨洋拉 aliyun，慢 3-5x

  =====================================================================
  Mirror / fallback 策略：
  =====================================================================
  解析顺序（按 settings 声明顺序）：

    aliyun-public  (mirror, 拦截 mirrorOf=central)
        ├─ 命中？ → 用（CN ~10 MB/s 飞快）
        └─ miss（aliyun metadata 偶尔滞后，如 spring-modulith 1.4.x patch）
              ↓
    tencent-public  (<repository>，不被 mirrorOf 拦截)
        ├─ 命中？ → 用（CN，仍快）
        └─ miss（spring-modulith 这类同步差的 group）
              ↓
    central-fallback  (Maven Central 直连，最终兜底)
        └─ 命中（Maven Central 是 source of truth，不会 miss）→ 用
              （跨洋 1-3 MB/s 慢但能完成）

  =====================================================================
  不同执行环境下的实际行为（本文件被 -s 加载时）：
  =====================================================================
  · 本地 dev docker build（CN）             aliyun 同 region 飞快        OK
  · 阿里云 ECS 上 build（CN region）        aliyun 同 region 内网飞快    OK+
  · 未来：阿里云作 GH self-hosted runner    aliyun 同 region 内网飞快    OK+
    （这是保留 -s 的主因）
  · GH Actions 默认 US runner build         aliyun 跨洋 1-2 MB/s 慢      OK-
    （release 频率低，可受）

  注：XML 注释里禁止两个连字符的连续序列（包括 markdown 表格分隔
  行那种），所以这里用 ASCII 列表 + 圆点代替表格。

  保留 `-s` 在 Dockerfile 的理由：未来若把 GH Actions runner 切成
  阿里云 self-hosted（同 region 跑 build），aliyun mirror = 飞快路径；
  即便短期内仍用 GH 默认 US runner，慢一点也可以接受。

  =====================================================================
  详细背景与同类问题（npm/pip/Go/Cargo/Gradle）的镜像策略：
  =====================================================================
  见 meta repo 本地 `docs/experience/docker-build-maven-mirror-strategy.md`
  （该 experience 目录已 untrack 入 .gitignore，仅本地保留，团队无 PR 流转）。
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0 https://maven.apache.org/xsd/settings-1.2.0.xsd">

  <mirrors>
    <mirror>
      <id>aliyun-public</id>
      <name>Aliyun Maven Public Mirror</name>
      <url>https://maven.aliyun.com/repository/public</url>
      <mirrorOf>central</mirrorOf>
    </mirror>
  </mirrors>

  <profiles>
    <profile>
      <id>multi-fallback</id>
      <repositories>
        <repository>
          <!--
            tencent-public：第二级 fallback。id 不为 'central'，逃过
            mirrorOf=central 拦截。aliyun miss 时优先在这里找，避免每次
            都跨洋打到 Maven Central。腾讯云对主流 Spring / Resilience4j
            等同步及时；个别 group（如 spring-modulith 系列）也偶有滞后，
            届时再 fall through 到 central-fallback。
          -->
          <id>tencent-public</id>
          <name>Tencent Cloud Maven Public Mirror</name>
          <url>https://mirrors.cloud.tencent.com/nexus/repository/maven-public/</url>
          <releases>
            <enabled>true</enabled>
          </releases>
          <snapshots>
            <enabled>false</enabled>
          </snapshots>
        </repository>
        <repository>
          <!--
            central-fallback：最终兜底。Maven Central 是 source of truth，
            上面两个 mirror 都 miss 时直连。跨洋慢但保证 build 不卡死。
          -->
          <id>central-fallback</id>
          <name>Maven Central (direct fallback)</name>
          <url>https://repo.maven.apache.org/maven2</url>
          <releases>
            <enabled>true</enabled>
          </releases>
          <snapshots>
            <enabled>false</enabled>
          </snapshots>
        </repository>
      </repositories>
      <pluginRepositories>
        <pluginRepository>
          <id>tencent-public</id>
          <name>Tencent Cloud Maven Public Mirror</name>
          <url>https://mirrors.cloud.tencent.com/nexus/repository/maven-public/</url>
          <releases>
            <enabled>true</enabled>
          </releases>
          <snapshots>
            <enabled>false</enabled>
          </snapshots>
        </pluginRepository>
        <pluginRepository>
          <id>central-fallback</id>
          <name>Maven Central (direct fallback)</name>
          <url>https://repo.maven.apache.org/maven2</url>
          <releases>
            <enabled>true</enabled>
          </releases>
          <snapshots>
            <enabled>false</enabled>
          </snapshots>
        </pluginRepository>
      </pluginRepositories>
    </profile>
  </profiles>

  <activeProfiles>
    <activeProfile>multi-fallback</activeProfile>
  </activeProfiles>

</settings>
