<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">
<!--
  Per-file Checkstyle suppressions.

  Keep this list short and well-justified — broad suppressions erode the ruleset.
  Prefer fixing code over adding suppressions.
-->
<suppressions>
    <!-- Spring Boot main classes have only a static main() method, which Checkstyle
         misidentifies as a utility class. Spring needs a public default constructor
         for reflection-based instantiation, so HideUtilityClassConstructor cannot apply. -->
    <suppress files=".*Application\.java" checks="HideUtilityClassConstructor"/>

    <!-- ArchUnit test classes hold static @ArchTest fields whose names use descriptive
         lowerCamelCase (ArchUnit's idiom, not constant naming). They also have only static
         members, triggering HideUtilityClassConstructor false-positive. -->
    <suppress files=".*Test\.java" checks="HideUtilityClassConstructor"/>
    <suppress files=".*Test\.java" checks="ConstantName"/>
    <suppress files=".*IT\.java" checks="HideUtilityClassConstructor"/>
    <suppress files=".*IT\.java" checks="ConstantName"/>

    <!-- Magic-number tolerance for tests: assertion ranges, timeouts, capacities,
         expected counts read clearly inline; extracting to named constants in tests
         hurts readability. Production code remains constrained. -->
    <suppress files=".*Test\.java" checks="MagicNumber"/>
    <suppress files=".*IT\.java" checks="MagicNumber"/>

    <!-- Test method naming follows CLAUDE.md § 七 convention: snake_case
         `should_X_when_Y` form is explicitly allowed alongside @DisplayName
         Chinese descriptions. Production code keeps strict camelCase. -->
    <suppress files=".*Test\.java" checks="MethodName"/>
    <suppress files=".*IT\.java" checks="MethodName"/>

    <!-- RateLimitService deliberately catches RuntimeException to provide a uniform
         fail-closed contract across all bucket4j / Lettuce / IO unchecked subtypes
         (ADR-0011 amended). Listing each subtype individually would drift as the
         libraries evolve and miss new failure modes. -->
    <suppress files=".*RateLimitService\.java" checks="IllegalCatch"/>

    <!-- AliyunSmsClient bridges two third-party API constraints we cannot change:
         1) Aliyun SDK's `Client.sendSms()` declares `throws Exception` (overly
            broad upstream signature)
         2) Resilience4j's `CheckedRunnable.run()` declares `throws Throwable`.
         A generic catch is unavoidable at this single integration boundary;
         the catch body immediately re-maps to SmsSendException so the contract
         outward stays narrow. Listing every concrete Tea SDK exception subtype
         would drift as the SDK evolves. -->
    <suppress files=".*AliyunSmsClient\.java" checks="IllegalCatch"/>

    <!-- AliyunRealnameClient mirrors the AliyunSmsClient suppression: the
         cloud-auth SDK's `Client.initFaceVerify` / `describeVerifyResult`
         both declare `throws Exception`. Catching Throwable at the integration
         boundary and immediately re-mapping to ProviderErrorException /
         ProviderTimeoutException keeps the outward contract narrow. -->
    <suppress files=".*AliyunRealnameClient\.java" checks="IllegalCatch"/>

    <!-- ResendEmailClient mirrors the AliyunSmsClient pattern: Resilience4j's
         `CheckedRunnable.run()` declares `throws Throwable`, so the wrapper
         catch around `Retry.decorateCheckedRunnable(...).run()` must be
         `catch (Throwable)` — narrower types do not compile. The catch body
         immediately re-maps to EmailSendException, so the outward contract
         stays narrow. -->
    <suppress files=".*ResendEmailClient\.java" checks="IllegalCatch"/>

    <!-- TimingDefenseExecutor.executeInConstantTime(Duration, Supplier, Predicate)
         catches RuntimeException uniformly so the user-supplied bypassPad
         predicate can inspect any business-disclosure subtype (per spec D
         expose-frozen-account-status FR-004 + CL-003). Listing each subtype
         (AccountInFreezePeriodException today; future disclosure paths
         tomorrow) would drift as new spec ships. Errors still propagate
         and trigger the pad — bypass is RuntimeException-only by design. -->
    <suppress files=".*TimingDefenseExecutor\.java" checks="IllegalCatch"/>

    <!-- FrozenAccountAnonymizationScheduler must keep its batch loop running
         across arbitrary use-case failures (Spring DataAccessException
         subtypes, Resilience4j wrappers, third-party transient errors).
         Listing each subtype would miss future failure modes; the catch
         block records the failure as a Micrometer counter and continues. -->
    <suppress files=".*FrozenAccountAnonymizationScheduler\.java" checks="IllegalCatch"/>
</suppressions>
